# Hugging Face API Configuration
HF_TOKEN=your_huggingface_api_token_here

# Local Model Configuration (Optional)
# Set to "True" to use local Ollama model instead of Hugging Face API
USE_LOCAL_MODEL=False

# Ollama Configuration (if using local model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Note: To use local models with Ollama:
# 1. Download Ollama from https://ollama.ai
# 2. Run: ollama pull mistral
# 3. Start Ollama server (it runs on port 11434 by default)
# 4. Set USE_LOCAL_MODEL=True in this .env file
