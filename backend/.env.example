# ==========================================
# GROQ API (Primary LLM - Recommended)
# ==========================================
# Get your key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ==========================================
# Flask Configuration
# ==========================================
FLASK_ENV=production
DEBUG=False

# ==========================================
# Render Specific Environment Variables
# ==========================================
# PORT: Automatically set by Render - no need to set it here
# PYTHONUNBUFFERED=true  (set this in Render dashboard)

# ==========================================
# Legacy: Hugging Face API Configuration (Optional)
# ==========================================
# Note: Groq is recommended instead
# HF_TOKEN=your_huggingface_api_token_here

# ==========================================
# Legacy: Local Model Configuration (Optional)
# ==========================================
# Set to "True" to use local Ollama model instead of Groq API
# Note: Not recommended on Render free tier (memory limited)
# USE_LOCAL_MODEL=False
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# To use local models with Ollama:
# 1. Download Ollama from https://ollama.ai
# 2. Run: ollama pull mistral
# 3. Start Ollama server (it runs on port 11434 by default)
# 4. Set USE_LOCAL_MODEL=True in this .env file
